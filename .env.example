# Environment variables for local development
# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real secrets.

# Anthropic API key — used by Netlify Functions server-side (never bundled
# into the browser). Get yours at https://console.anthropic.com.
# DO NOT prefix with VITE_ — that would expose it to browser code.
ANTHROPIC_API_KEY=sk-ant-your-key-here
