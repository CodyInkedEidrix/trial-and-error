# Environment variables for local development
# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real secrets.

# Anthropic API key — used by Netlify Functions server-side (never bundled
# into the browser). Get yours at https://console.anthropic.com.
# DO NOT prefix with VITE_ — that would expose it to browser code.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase — the database + auth backend.
# Local dev: `npx supabase status` prints these after `supabase start`.
# Production: set in Netlify dashboard with the cloud project's values.
# Anon/publishable key is browser-safe — RLS enforces tenant isolation.
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=sb_publishable_your-local-or-cloud-key-here

# Server-side mirrors — used by Netlify Functions to construct per-
# request Supabase clients with the user's JWT (so RLS applies).
# Same values as the VITE_ pair; the un-prefixed names just signal
# server-only intent. AC-02 onward depends on these being set.
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=sb_publishable_your-local-or-cloud-key-here

# Dev-only UI surfaces (Agent Debug tab, etc.) — 'true' shows them,
# anything else (including unset) hides them. Local dev + deploy
# previews should be 'true'; production deploys should be 'false'.
VITE_DEV_MODE=true

# Secret used to HMAC-sign confirmation tokens for destructive tool
# calls (AC-03 Session 2). Any 32+ character random string. Rotate by
# setting a new value; in-flight tokens TTL out in 5 min.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Never prefix with VITE_ — this stays server-side.
EIDRIX_CONFIRM_SECRET=generate-me-with-crypto-randomBytes-48-base64url

# Voyage AI — embeddings provider for agent memory (AC-04 Session 2).
# Free tier gives ~200M tokens, which is plenty for Trial and Error
# and early real Eidrix. Get yours at https://dash.voyageai.com.
# Never prefix with VITE_ — this stays server-side.
VOYAGE_API_KEY=pa-your-voyage-key-here

# NEVER prefix the service role key with VITE_ — it bypasses RLS.
# Goes in Netlify env only, server-side only, if Edge Functions need it.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
